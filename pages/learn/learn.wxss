/* pages/learn/learn.wxss */

/* ─── Introduction Card ─────────────────────────────────────────────────────── */
.intro-card {
  background: #FFFFFF;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
  border-left: 6rpx solid #2E86C1;
}

.intro-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.intro-card-left {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.intro-card-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
}

.intro-card-titles {
  display: flex;
  flex-direction: column;
}

.intro-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E1008;
}

.intro-card-subtitle {
  font-size: 22rpx;
  color: #6B8BA4;
  margin-top: 4rpx;
}

.intro-card-chevron {
  font-size: 24rpx;
  color: #9B8070;
  padding: 8rpx;
}

.intro-card-body {
  margin-top: 20rpx;
}

.intro-section {
  margin-bottom: 4rpx;
}

.intro-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C1810;
  display: block;
  margin-bottom: 12rpx;
}

.intro-section-text {
  font-size: 26rpx;
  color: #4A3828;
  line-height: 1.7;
  display: block;
  margin-bottom: 16rpx;
}

.inline-it {
  color: #C1440E;
  font-weight: 600;
}

.intro-divider {
  height: 1rpx;
  background: #F0E0D0;
  margin: 20rpx 0;
}

.intro-tip {
  font-size: 24rpx;
  color: #6B8BA4;
  line-height: 1.6;
  display: block;
  background: #EDF7FF;
  padding: 12rpx 16rpx;
  border-radius: 10rpx;
  margin-top: 8rpx;
}

/* 句子拆解 */
.sentence-breakdown {
  background: #FAF0E6;
  border-radius: 14rpx;
  padding: 18rpx;
  margin-bottom: 16rpx;
}

.breakdown-row {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.breakdown-cell {
  flex: 1;
  border-radius: 10rpx;
  padding: 14rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cell-verb    { background: #FDE8E0; border: 2rpx solid #F0A080; }
.cell-article { background: #E8F0FF; border: 2rpx solid #90B0E8; }
.cell-noun    { background: #E8F5E0; border: 2rpx solid #90C870; }

.breakdown-word {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C1810;
}

.breakdown-tag {
  font-size: 18rpx;
  color: #6B5548;
  margin-top: 4rpx;
  text-align: center;
}

.breakdown-meaning {
  font-size: 24rpx;
  color: #6B5548;
  display: block;
  text-align: center;
}

/* 冠词网格 */
.article-grid {
  background: #FAF0E6;
  border-radius: 14rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.article-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.article-row:last-child { margin-bottom: 0; }

.article-cell {
  flex: 1;
  background: #FFFFFF;
  border-radius: 10rpx;
  padding: 12rpx 14rpx;
}

.article-word {
  font-size: 26rpx;
  font-weight: 700;
  color: #C1440E;
  display: block;
}

.article-cn {
  font-size: 20rpx;
  color: #6B5548;
  margin-top: 4rpx;
  display: block;
}

/* 动词变位表 */
.conjugation-table {
  background: #FAF0E6;
  border-radius: 14rpx;
  padding: 4rpx 16rpx;
  margin-bottom: 16rpx;
}

.conj-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #EDD8C8;
}

.conj-row:last-child { border-bottom: none; }

.conj-person {
  width: 80rpx;
  font-size: 24rpx;
  color: #6B5548;
}

.conj-form {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #C1440E;
}

.conj-note {
  font-size: 20rpx;
  color: #9B8070;
  font-style: italic;
}

/* 课程路径概览 */
.path-overview {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.path-ov-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #FAF8F5;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
}

.path-ov-badge {
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.path-ov-text {
  font-size: 24rpx;
  color: #4A3828;
  line-height: 1.5;
  flex: 1;
}

/* ─── Base ─────────────────────────────────────────────────────────────────── */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5EDE3;
}

.main-scroll {
  flex: 1;
  overflow: hidden;
}

.bottom-space {
  height: 60rpx;
}

/* ─── Hero ──────────────────────────────────────────────────────────────────── */
.hero-section {
  background: linear-gradient(135deg, #C1440E 0%, #7A2A08 100%);
  padding: 28rpx 30rpx 24rpx;
}

.hero-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
}

.hero-flag {
  font-size: 56rpx;
  margin-right: 18rpx;
}

.hero-text {
  display: flex;
  flex-direction: column;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 4rpx;
}

.hero-stats {
  display: flex;
  flex-direction: row;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 16rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  background: rgba(255,255,255,0.25);
  margin: 6rpx 0;
}

/* ─── Level Block ───────────────────────────────────────────────────────────── */
.level-block {
  background: #FFFFFF;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.07);
}

.level-block.level-locked {
  opacity: 0.7;
}

.level-connector {
  width: 3rpx;
  height: 28rpx;
  background: linear-gradient(#DDD, #DDD);
  margin: 0 auto;
  border-left: 3rpx dashed #D0BFB0;
}

/* Level Header */
.level-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.level-badge {
  font-size: 20rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.badge-0 { background: #E8F4FD; color: #2E86C1; }
.badge-1 { background: #FEF0E6; color: #C1440E; }
.badge-2 { background: #EBF5E0; color: #4A7A1E; }
.badge-3 { background: #F3E8FF; color: #7B2FA6; }

.level-header-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.level-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1E1008;
}

.level-desc {
  font-size: 22rpx;
  color: #9B8070;
  margin-top: 2rpx;
}

.level-progress-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #C1440E;
}

.level-lock-icon {
  font-size: 30rpx;
}

.level-check {
  font-size: 30rpx;
}

.level-chevron {
  font-size: 22rpx;
  color: #9B8070;
  margin-left: 10rpx;
  padding: 4rpx;
}

/* Level Progress Bar */
.level-progress-bar {
  height: 8rpx;
  background: #EDE0D5;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.level-progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.fill-1 { background: linear-gradient(90deg, #C1440E, #E8622A); }
.fill-2 { background: linear-gradient(90deg, #4A7A1E, #72B030); }
.fill-3 { background: linear-gradient(90deg, #7B2FA6, #A855D8); }

/* Locked hint */
.unlock-hint {
  font-size: 24rpx;
  color: #A08878;
  text-align: center;
  padding: 16rpx;
  background: #FAF0E6;
  border-radius: 12rpx;
  margin-top: 4rpx;
}

.level-tip {
  font-size: 24rpx;
  color: #A08878;
  text-align: center;
  margin-top: 12rpx;
  padding: 12rpx;
  background: #FFF8F0;
  border-radius: 10rpx;
}

/* ─── Phonics Card ──────────────────────────────────────────────────────────── */
.phonics-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #F5F0FF;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 2rpx solid #E0D5F5;
}

.phonics-left {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.phonics-icon-bg {
  width: 72rpx;
  height: 72rpx;
  background: #7B2FA6;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.phonics-icon {
  font-size: 36rpx;
}

.phonics-info {
  display: flex;
  flex-direction: column;
}

.phonics-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C1810;
}

.phonics-hint {
  font-size: 22rpx;
  color: #9B8070;
  margin-top: 4rpx;
}

.phonics-action {
  flex-shrink: 0;
}

.phonics-arrow {
  font-size: 26rpx;
  color: #7B2FA6;
  font-weight: 600;
}

/* ─── Path Nodes ────────────────────────────────────────────────────────────── */
.path-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.path-node-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.node-connector {
  width: 3rpx;
  height: 24rpx;
  background: #DDD;
  border-left: 3rpx dashed #D0BFB0;
}

.node-connector.connector-done {
  border-left: 3rpx solid #6B7C3B;
  background: none;
}

.path-node {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid #EDE0D5;
  background: #FFFFFF;
}

.path-node.node-done {
  border-color: #6B7C3B;
  background: #F4FAF0;
}

.path-node.node-locked {
  opacity: 0.5;
  background: #F8F4F0;
}

.path-node.node-available {
  border-color: #F0A080;
  background: #FFFAF8;
}

.node-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #FAF0E6;
  border: 3rpx solid #E0C8B5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.node-done .node-circle {
  background: #6B7C3B;
  border-color: #6B7C3B;
}

.node-available .node-circle {
  background: #FEF0E6;
  border-color: #C1440E;
}

.node-icon {
  font-size: 28rpx;
  color: #C1440E;
  line-height: 1;
}

.done-icon {
  color: #FFFFFF;
  font-weight: 700;
}

.node-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #2C1810;
}

.node-done .node-label {
  color: #4A6010;
}

.node-meta {
  font-size: 22rpx;
  color: #A08878;
}

/* Finish flag */
.path-finish {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.finish-flag {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(135deg, #F0A020, #E87820);
  border-radius: 50rpx;
  padding: 16rpx 32rpx;
  margin-top: 4rpx;
}

.finish-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.finish-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* ─── Level 3 Teaser ────────────────────────────────────────────────────────── */
.teaser-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 8rpx 0 16rpx;
}

.teaser-item {
  flex: 1;
  min-width: 140rpx;
  background: #F8F0FF;
  border-radius: 14rpx;
  padding: 18rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.teaser-emoji {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.teaser-name {
  font-size: 22rpx;
  color: #7B2FA6;
  font-weight: 600;
  text-align: center;
}

/* ─── Bottom Sheet (共用) ────────────────────────────────────────────────────── */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.bottom-sheet {
  background: #FFFFFF;
  border-radius: 30rpx 30rpx 0 0;
  width: 100%;
  height: 90vh;
  display: flex;
  flex-direction: column;
}

.lesson-sheet {
  height: 88vh;
}

.lesson-sheet .sheet-scroll {
  height: calc(88vh - 120rpx);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  background: #E0D5C8;
  border-radius: 4rpx;
  margin: 16rpx auto 0;
  flex-shrink: 0;
}

.sheet-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 30rpx 16rpx;
  border-bottom: 1rpx solid #F0E0D0;
  flex-shrink: 0;
}

.sheet-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #2C1810;
}

.sheet-close {
  font-size: 32rpx;
  color: #8B7265;
  padding: 8rpx;
}

.sheet-scroll {
  flex: 1;
  /* 微信小程序 scroll-view 必须给固定高度才能滚动，用 calc 减去 handle+header */
  height: calc(90vh - 120rpx);
  box-sizing: border-box;
  padding: 0 30rpx;
}

/* Sheet sections */
.sheet-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #C1440E;
  margin: 24rpx 0 12rpx;
}

/* ─── Phonics content ───────────────────────────────────────────────────────── */
.vowels-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-bottom: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.vowel-pill {
  flex: 1;
  min-width: 0;
  background: #FEF0E6;
  border-radius: 14rpx;
  padding: 18rpx 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid #F0C8A0;
  box-sizing: border-box;
}

.vowel-letter {
  font-size: 44rpx;
  font-weight: 800;
  color: #C1440E;
  line-height: 1.1;
}

.vowel-phonetic {
  font-size: 22rpx;
  color: #6B7C3B;
  font-weight: 600;
  margin-top: 4rpx;
}

.vowel-tts {
  font-size: 20rpx;
  margin-top: 6rpx;
  opacity: 0.6;
}

.rule-card {
  background: #FAF0E6;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 20rpx;
}

.rule-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 14rpx;
}

.rule-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.rule-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C1810;
}

.rule-row {
  background: #FFFFFF;
  border-radius: 10rpx;
  padding: 12rpx 14rpx;
  margin-bottom: 8rpx;
}

.rule-pattern-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 4rpx;
}

.pattern-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #C1440E;
  font-family: monospace;
}

.pattern-arrow {
  font-size: 22rpx;
  color: #A08878;
  margin: 0 10rpx;
}

.pattern-sound {
  font-size: 26rpx;
  font-weight: 600;
  color: #6B7C3B;
}

.rule-example {
  font-size: 22rpx;
  color: #6B7265;
}

.alphabet-note {
  font-size: 22rpx;
  color: #A08878;
  margin-bottom: 14rpx;
  font-style: italic;
  display: block;
}

.alphabet-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.alpha-item {
  background: #FFFFFF;
  border-radius: 12rpx;
  width: 198rpx;
  padding: 14rpx 12rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.alpha-letter {
  font-size: 40rpx;
  font-weight: 800;
  color: #C1440E;
  line-height: 1.2;
}

.alpha-name {
  font-size: 20rpx;
  color: #A08878;
  font-style: italic;
}

.alpha-phonetic {
  font-size: 18rpx;
  color: #6B7C3B;
  text-align: center;
  margin-top: 4rpx;
}

.alpha-tts-btn {
  font-size: 22rpx;
  margin-top: 8rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  background: rgba(193, 68, 14, 0.08);
}

.tips-card {
  background: #FFF8E8;
  border-radius: 14rpx;
  padding: 20rpx;
  border-left: 4rpx solid #F0A020;
  margin-bottom: 8rpx;
}

.tip-row {
  display: flex;
  flex-direction: row;
  margin-bottom: 10rpx;
}

.tip-dot {
  color: #C1440E;
  font-size: 26rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #2C1810;
  line-height: 1.6;
}

/* ─── Lesson Modal Content ──────────────────────────────────────────────────── */
.lesson-context-hint {
  background: #EDF7FF;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  margin-top: 16rpx;
}

.context-hint-text {
  font-size: 22rpx;
  color: #2E86C1;
}

.vocab-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx;
  background: #FAF0E6;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
  box-sizing: border-box;
  width: 100%;
}

.vocab-left {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.vocab-italian {
  font-size: 30rpx;
  font-weight: 700;
  color: #C1440E;
}

.vocab-tts-hint {
  font-size: 20rpx;
  opacity: 0.5;
  margin-left: 8rpx;
}

.vocab-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.vocab-chinese {
  font-size: 26rpx;
  color: #2C1810;
  font-weight: 600;
}

.vocab-pronunciation {
  font-size: 22rpx;
  color: #8B7265;
  font-style: italic;
  margin-top: 2rpx;
}

.grammar-box {
  background: #FFF8E8;
  border-radius: 12rpx;
  padding: 20rpx;
  border-left: 4rpx solid #F0A020;
  margin-bottom: 10rpx;
}

.grammar-text {
  font-size: 26rpx;
  color: #2C1810;
  line-height: 1.7;
}

.exercise-box {
  background: #FAF0E6;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 10rpx;
}

.exercise-question {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C1810;
  display: block;
  margin-bottom: 16rpx;
}

.exercise-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 10rpx;
  border: 2rpx solid #E8D5C4;
}

.exercise-option.selected { border-color: #C1440E; background: #FFF4F0; }
.exercise-option.correct  { background: #EBF0E0; border-color: #6B7C3B; }
.exercise-option.wrong    { background: #FCE8E0; border-color: #C1440E; }

.option-letter {
  font-size: 22rpx;
  font-weight: 700;
  color: #C1440E;
  width: 36rpx;
}

.option-text {
  font-size: 26rpx;
  color: #2C1810;
  flex: 1;
}

.answer-feedback {
  padding: 16rpx;
  border-radius: 12rpx;
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}

.correct-fb { background: #EBF0E0; color: #6B7C3B; }
.wrong-fb   { background: #FFF3E8; color: #C1440E; }

/* ─── Complete Button (共用) ────────────────────────────────────────────────── */
.complete-btn-wrap {
  padding: 20rpx 0 10rpx;
}

.complete-btn {
  background: linear-gradient(135deg, #C1440E, #E8622A);
  color: #FFFFFF;
  border-radius: 50rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(193, 68, 14, 0.35);
}

.complete-btn.already-done {
  background: linear-gradient(135deg, #6B7C3B, #8FAA4E);
  box-shadow: 0 6rpx 20rpx rgba(107, 124, 59, 0.3);
}
