<!-- pages/learn/learn.wxml -->
<view class="page-container">

  <!-- ===== Hero Section ===== -->
  <view class="hero-section">
    <view class="hero-content">
      <text class="hero-flag">🇮🇹</text>
      <view class="hero-text">
        <text class="hero-title">意大利语学习路径</text>
        <text class="hero-subtitle">从零基础到开口说话</text>
      </view>
    </view>
    <view class="hero-stats">
      <view class="stat-item">
        <text class="stat-num">{{totalCompleted}}</text>
        <text class="stat-label">已完成课程</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{totalVocab}}</text>
        <text class="stat-label">掌握词汇</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{currentLevelLabel}}</text>
        <text class="stat-label">当前阶段</text>
      </view>
    </view>
  </view>

  <scroll-view class="main-scroll" scroll-y="true" enhanced="true" bounces="true">

    <!-- ===== Introduction Card ===== -->
    <view class="intro-card" bindtap="onToggleIntro">
      <view class="intro-card-header">
        <view class="intro-card-left">
          <text class="intro-card-icon">🧭</text>
          <view class="intro-card-titles">
            <text class="intro-card-title">意大利语入门导览</text>
            <text class="intro-card-subtitle">学前必读 · 2分钟建立语言框架</text>
          </view>
        </view>
        <text class="intro-card-chevron">{{showIntro ? '▲' : '▼'}}</text>
      </view>

      <view wx:if="{{showIntro}}" class="intro-card-body" catchtap="stopPropagation">
        <view class="intro-section">
          <text class="intro-section-title">📐 句子结构：和英语很像</text>
          <text class="intro-section-text">意大利语基本结构是主谓宾，跟中文、英文一样。但有一个关键区别——主语「我/你/他」通常可以省略，因为动词本身的变化已经表达了是谁在说话。</text>
          <view class="sentence-breakdown">
            <view class="breakdown-row">
              <view class="breakdown-cell cell-verb">
                <text class="breakdown-word">Voglio</text>
                <text class="breakdown-tag">动词「想要」</text>
              </view>
              <view class="breakdown-cell cell-article">
                <text class="breakdown-word">una</text>
                <text class="breakdown-tag">冠词「一个」</text>
              </view>
              <view class="breakdown-cell cell-noun">
                <text class="breakdown-word">pizza</text>
                <text class="breakdown-tag">名词「披萨」</text>
              </view>
            </view>
            <text class="breakdown-meaning">= 我想要一个披萨（主语「我」省略了）</text>
          </view>
        </view>

        <view class="intro-divider"></view>

        <view class="intro-section">
          <text class="intro-section-title">🏷️ 为什么每个名词前都有个词？</text>
          <text class="intro-section-text">意大利语里名词分「阳性」和「阴性」，冠词要跟名词性别匹配：</text>
          <view class="article-grid">
            <view class="article-row">
              <view class="article-cell">
                <text class="article-word">un caffè</text>
                <text class="article-cn">一杯咖啡（阳性）</text>
              </view>
              <view class="article-cell">
                <text class="article-word">una pizza</text>
                <text class="article-cn">一个披萨（阴性）</text>
              </view>
            </view>
            <view class="article-row">
              <view class="article-cell">
                <text class="article-word">il menu</text>
                <text class="article-cn">菜单（阳性定冠词）</text>
              </view>
              <view class="article-cell">
                <text class="article-word">la stazione</text>
                <text class="article-cn">车站（阴性定冠词）</text>
              </view>
            </view>
          </view>
          <text class="intro-tip">💡 现阶段不用记规则，课程里见到多了自然有感觉。</text>
        </view>

        <view class="intro-divider"></view>

        <view class="intro-section">
          <text class="intro-section-title">🔀 动词会「变形」</text>
          <text class="intro-section-text">同一个动词，不同的人说时写法不同。这叫「动词变位」。比如「是」这个动词：</text>
          <view class="conjugation-table">
            <view class="conj-row">
              <text class="conj-person">我</text>
              <text class="conj-form">sono</text>
              <text class="conj-note">主语常省略</text>
            </view>
            <view class="conj-row">
              <text class="conj-person">你</text>
              <text class="conj-form">sei</text>
              <text class="conj-note"></text>
            </view>
            <view class="conj-row">
              <text class="conj-person">他/她</text>
              <text class="conj-form">è</text>
              <text class="conj-note"></text>
            </view>
          </view>
          <text class="intro-tip">💡 第一阶段会系统学变位，现在只需要认识这个现象。</text>
        </view>

        <view class="intro-divider"></view>

        <view class="intro-section">
          <text class="intro-section-title">🗺️ 这套课程怎么安排的</text>
          <view class="path-overview">
            <view class="path-ov-item">
              <view class="path-ov-badge badge-0">基础</view>
              <text class="path-ov-text">发音规则 — 先搞懂意大利字母怎么发音</text>
            </view>
            <view class="path-ov-item">
              <view class="path-ov-badge badge-foundation">语法</view>
              <text class="path-ov-text">语言基础 — 人称、动词变位、名词性别、物主代词</text>
            </view>
            <view class="path-ov-item">
              <view class="path-ov-badge badge-verbs">动词</view>
              <text class="path-ov-text">核心动词 — 8个高频动词 + 完整变位表</text>
            </view>
            <view class="path-ov-item">
              <view class="path-ov-badge badge-1">场景</view>
              <text class="path-ov-text">旅行场景 — 餐厅、交通、购物、酒店等实战词汇</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== Level 0: 发音入门 ===== -->
    <view class="level-block">
      <view class="level-header">
        <view class="level-badge badge-0">基础</view>
        <view class="level-header-text">
          <text class="level-title">发音入门</text>
          <text class="level-desc">先搞懂意大利语的声音系统</text>
        </view>
        <text class="level-check {{phonicsCompleted ? 'done' : ''}}">{{phonicsCompleted ? '✅' : ''}}</text>
      </view>
      <view class="phonics-card" bindtap="onOpenPhonics">
        <view class="phonics-left">
          <view class="phonics-icon-bg">
            <text class="phonics-icon">🔤</text>
          </view>
          <view class="phonics-info">
            <text class="phonics-name">字母 & 发音规则</text>
            <text class="phonics-hint">21个字母 · 7条核心规则 · 发音贴士</text>
          </view>
        </view>
        <view class="phonics-action">
          <text class="phonics-arrow">{{phonicsCompleted ? '复习 ›' : '开始 ›'}}</text>
        </view>
      </view>
    </view>

    <!-- ===== 第一阶段：语言基础 ===== -->
    <view class="level-connector"></view>
    <view class="level-block">
      <view class="level-header" bindtap="onToggleFoundation">
        <view class="level-badge badge-foundation">语法</view>
        <view class="level-header-text">
          <text class="level-title">语言基础</text>
          <text class="level-desc">人称 · 动词变位 · 名词性别 · 物主代词</text>
        </view>
        <text class="level-progress-text">{{foundationCompleted}}/{{foundationTotal}}</text>
        <text class="level-chevron">{{showFoundation ? '▲' : '▼'}}</text>
      </view>

      <view wx:if="{{showFoundation}}">
        <view class="level-progress-bar">
          <view class="level-progress-fill fill-foundation" style="width: {{foundationTotal > 0 ? foundationCompleted / foundationTotal * 100 : 0}}%"></view>
        </view>
        <view class="path-container">
          <view wx:for="{{foundationLessons}}" wx:key="id" class="path-node-wrap">
            <view wx:if="{{index > 0}}" class="node-connector {{lessonProgress[foundationLessons[index-1].id] ? 'connector-done' : ''}}"></view>
            <view class="path-node {{lessonProgress[item.id] ? 'node-done' : 'node-available'}}" bindtap="onLessonTap" data-id="{{item.id}}">
              <view class="node-circle">
                <text wx:if="{{lessonProgress[item.id]}}" class="node-icon done-icon">✓</text>
                <text wx:else class="node-icon">{{item.emoji}}</text>
              </view>
              <text class="node-label">{{item.title}}</text>
              <text class="node-meta">{{item.vocab.length}}词 · {{item.time}}</text>
            </view>
          </view>
          <view wx:if="{{foundationCompleted === foundationTotal}}" class="path-finish">
            <view class="node-connector connector-done"></view>
            <view class="finish-flag">
              <text class="finish-icon">🏆</text>
              <text class="finish-text">语言基础掌握！</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== 第二阶段：核心动词 ===== -->
    <view class="level-connector"></view>
    <view class="level-block">
      <view class="level-header" bindtap="onToggleVerbs">
        <view class="level-badge badge-verbs">动词</view>
        <view class="level-header-text">
          <text class="level-title">核心动词</text>
          <text class="level-desc">8个高频动词 + 完整变位表</text>
        </view>
        <text class="level-progress-text">{{verbsCompleted}}/{{verbsTotal}}</text>
        <text class="level-chevron">{{showVerbs ? '▲' : '▼'}}</text>
      </view>

      <view wx:if="{{showVerbs}}">
        <view class="level-progress-bar">
          <view class="level-progress-fill fill-verbs" style="width: {{verbsTotal > 0 ? verbsCompleted / verbsTotal * 100 : 0}}%"></view>
        </view>
        <view class="path-container">
          <view wx:for="{{verbsLessons}}" wx:key="id" class="path-node-wrap">
            <view wx:if="{{index > 0}}" class="node-connector {{lessonProgress[verbsLessons[index-1].id] ? 'connector-done' : ''}}"></view>
            <view class="path-node {{lessonProgress[item.id] ? 'node-done' : 'node-available'}}" bindtap="onLessonTap" data-id="{{item.id}}">
              <view class="node-circle">
                <text wx:if="{{lessonProgress[item.id]}}" class="node-icon done-icon">✓</text>
                <text wx:else class="node-icon">{{item.emoji}}</text>
              </view>
              <text class="node-label">{{item.title}}</text>
              <text class="node-meta">{{item.vocab.length}}词 · {{item.time}}</text>
            </view>
          </view>
          <view wx:if="{{verbsCompleted === verbsTotal}}" class="path-finish">
            <view class="node-connector connector-done"></view>
            <view class="finish-flag">
              <text class="finish-icon">🏆</text>
              <text class="finish-text">核心动词全部掌握！</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== 旅行场景 L1 ===== -->
    <view class="level-connector"></view>
    <view class="level-block">
      <view class="level-header" bindtap="onToggleSceneL1">
        <view class="level-badge badge-1">场景</view>
        <view class="level-header-text">
          <text class="level-title">旅行生存包</text>
          <text class="level-desc">完成后能独立搞定一次意大利之旅</text>
        </view>
        <text class="level-progress-text">{{sceneL1Completed}}/{{sceneL1Total}}</text>
        <text class="level-chevron">{{showSceneL1 ? '▲' : '▼'}}</text>
      </view>

      <view wx:if="{{showSceneL1}}">
        <view class="level-progress-bar">
          <view class="level-progress-fill fill-1" style="width: {{sceneL1Total > 0 ? sceneL1Completed / sceneL1Total * 100 : 0}}%"></view>
        </view>
        <view class="path-container">
          <view wx:for="{{sceneL1Lessons}}" wx:key="id" class="path-node-wrap">
            <view wx:if="{{index > 0}}" class="node-connector {{lessonProgress[sceneL1Lessons[index-1].id] ? 'connector-done' : ''}}"></view>
            <view class="path-node {{lessonProgress[item.id] ? 'node-done' : 'node-available'}}" bindtap="onLessonTap" data-id="{{item.id}}">
              <view class="node-circle">
                <text wx:if="{{lessonProgress[item.id]}}" class="node-icon done-icon">✓</text>
                <text wx:else class="node-icon">{{item.emoji}}</text>
              </view>
              <text class="node-label">{{item.title}}</text>
              <text class="node-meta">{{item.vocab.length}}词 · {{item.time}}</text>
            </view>
          </view>
          <view wx:if="{{sceneL1Completed === sceneL1Total}}" class="path-finish">
            <view class="node-connector connector-done"></view>
            <view class="finish-flag">
              <text class="finish-icon">🏆</text>
              <text class="finish-text">旅行生存包完成！</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== 旅行场景 L2 ===== -->
    <view class="level-connector"></view>
    <view class="level-block">
      <view class="level-header" bindtap="onToggleSceneL2">
        <view class="level-badge badge-2">进阶</view>
        <view class="level-header-text">
          <text class="level-title">日常会话</text>
          <text class="level-desc">跟当地人进行简单对话</text>
        </view>
        <text class="level-progress-text">{{sceneL2Completed}}/{{sceneL2Total}}</text>
        <text class="level-chevron">{{showSceneL2 ? '▲' : '▼'}}</text>
      </view>

      <view wx:if="{{showSceneL2}}">
        <view class="level-progress-bar">
          <view class="level-progress-fill fill-2" style="width: {{sceneL2Total > 0 ? sceneL2Completed / sceneL2Total * 100 : 0}}%"></view>
        </view>
        <view class="path-container">
          <view wx:for="{{sceneL2Lessons}}" wx:key="id" class="path-node-wrap">
            <view wx:if="{{index > 0}}" class="node-connector {{lessonProgress[sceneL2Lessons[index-1].id] ? 'connector-done' : ''}}"></view>
            <view class="path-node {{lessonProgress[item.id] ? 'node-done' : 'node-available'}}" bindtap="onLessonTap" data-id="{{item.id}}">
              <view class="node-circle">
                <text wx:if="{{lessonProgress[item.id]}}" class="node-icon done-icon">✓</text>
                <text wx:else class="node-icon">{{item.emoji}}</text>
              </view>
              <text class="node-label">{{item.title}}</text>
              <text class="node-meta">{{item.vocab.length}}词 · {{item.time}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>

  <!-- ===== Phonics Sheet ===== -->
  <view class="modal-overlay" wx:if="{{showPhonics}}" bindtap="onClosePhonics">
    <view class="bottom-sheet" catchtap="stopPropagation">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <text class="sheet-title">🔤 意大利语发音指南</text>
        <view class="sheet-close" bindtap="onClosePhonics">✕</view>
      </view>
      <scroll-view class="sheet-scroll" scroll-y="true">
        <view class="sheet-section-title">五个元音</view>
        <view class="vowels-row">
          <view wx:for="{{vowels}}" wx:key="letter" class="vowel-pill" bindtap="onVowelTap" data-letter="{{item.letter}}">
            <text class="vowel-letter">{{item.letter}}</text>
            <text class="vowel-phonetic">{{item.phonetic}}</text>
            <text class="vowel-tts">🔊</text>
          </view>
        </view>
        <view class="sheet-section-title">核心发音规则</view>
        <view wx:for="{{consonantRules}}" wx:key="title" class="rule-card">
          <view class="rule-header">
            <text class="rule-icon">{{item.icon}}</text>
            <text class="rule-title">{{item.title}}</text>
          </view>
          <view wx:for="{{item.rules}}" wx:for-item="rule" wx:key="pattern" class="rule-row">
            <view class="rule-pattern-row">
              <text class="pattern-text">{{rule.pattern}}</text>
              <text class="pattern-arrow">→</text>
              <text class="pattern-sound">{{rule.sound}}</text>
            </view>
            <text class="rule-example">例：{{rule.example}}</text>
          </view>
        </view>
        <view class="sheet-section-title">完整字母表（21字母）</view>
        <text class="alphabet-note">意大利字母表没有 J K W X Y（仅用于外来词）</text>
        <view class="alphabet-grid">
          <view wx:for="{{alphabet}}" wx:key="letter" class="alpha-item" bindtap="onLetterTTSTap" data-letter="{{item.letter}}">
            <text class="alpha-letter">{{item.letter}}</text>
            <text class="alpha-name">{{item.name}}</text>
            <text class="alpha-phonetic">{{item.phonetic}}</text>
            <view class="alpha-tts-btn">🔊</view>
          </view>
        </view>
        <view class="sheet-section-title">发音贴士</view>
        <view class="tips-card">
          <view wx:for="{{phonicsTips}}" wx:key="*this" class="tip-row">
            <text class="tip-dot">•</text>
            <text class="tip-text">{{item}}</text>
          </view>
        </view>
        <view class="complete-btn-wrap">
          <view class="complete-btn {{phonicsCompleted ? 'already-done' : ''}}" bindtap="onCompletePhonics">
            <text>{{phonicsCompleted ? '✅ 已掌握发音基础' : '🎓 完成发音入门'}}</text>
          </view>
        </view>
        <view style="height: 60rpx;"></view>
      </scroll-view>
    </view>
  </view>

  <!-- ===== Lesson Modal ===== -->
  <view class="modal-overlay" wx:if="{{showLessonModal}}" bindtap="onCloseLessonModal">
    <view class="bottom-sheet lesson-sheet" catchtap="stopPropagation">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <text class="sheet-title">{{currentLesson.emoji}} {{currentLesson.title}}</text>
        <view class="sheet-close" bindtap="onCloseLessonModal">✕</view>
      </view>

      <scroll-view class="sheet-scroll" scroll-y="true">

        <!-- 词汇 -->
        <view class="sheet-section-title">📖 词汇（{{currentLesson.vocab.length}}个）</view>
        <view wx:for="{{currentLesson.vocab}}" wx:key="italian"
          class="vocab-item"
          bindtap="onVocabTTSTap"
          data-idx="{{index}}">
          <view class="vocab-left">
            <text class="vocab-italian">{{item.italian}}</text>
            <text class="vocab-tts-hint">🔊</text>
          </view>
          <view class="vocab-right">
            <text class="vocab-chinese">{{item.chinese}}</text>
            <text class="vocab-pronunciation">{{item.pronunciation}}</text>
          </view>
        </view>

        <!-- 变位表（仅动词课程显示） -->
        <view wx:if="{{currentLesson.conjugation}}">
          <view class="sheet-section-title">📊 {{currentLesson.conjugation.title}}</view>
          <view class="conj-modal-table">
            <view class="conj-modal-header">
              <text class="conj-modal-th">人称</text>
              <text class="conj-modal-th th-form">变位形式</text>
              <text class="conj-modal-th">含义</text>
            </view>
            <view wx:for="{{currentLesson.conjugation.rows}}" wx:key="person" class="conj-modal-row {{index % 2 === 0 ? 'row-even' : ''}}">
              <text class="conj-modal-person">{{item.person}}</text>
              <text class="conj-modal-form">{{item.form}}</text>
              <text class="conj-modal-meaning">{{item.meaning}}</text>
            </view>
          </view>
        </view>

        <!-- 语法说明 -->
        <view class="sheet-section-title">📐 语法说明</view>
        <view class="grammar-box">
          <text class="grammar-text">{{currentLesson.grammar}}</text>
        </view>

        <!-- 练习 -->
        <view class="sheet-section-title">✏️ 小练习</view>
        <view class="exercise-box">
          <text class="exercise-question">{{currentLesson.exercise.question}}</text>
          <view
            wx:for="{{currentLesson.exercise.options}}"
            wx:key="*this"
            wx:for-index="optIdx"
            class="exercise-option
              {{lessonAnswered && optIdx === currentLesson.exercise.answer ? 'correct' : ''}}
              {{lessonAnswered && selectedOption === optIdx && optIdx !== currentLesson.exercise.answer ? 'wrong' : ''}}
              {{selectedOption === optIdx && !lessonAnswered ? 'selected' : ''}}"
            bindtap="{{lessonAnswered ? '' : 'onAnswerSelect'}}"
            data-idx="{{optIdx}}"
          >
            <text class="option-letter">{{optIdx === 0 ? 'A' : optIdx === 1 ? 'B' : optIdx === 2 ? 'C' : 'D'}}</text>
            <text class="option-text">{{item}}</text>
            <text wx:if="{{lessonAnswered && optIdx === currentLesson.exercise.answer}}"> ✓</text>
            <text wx:if="{{lessonAnswered && selectedOption === optIdx && optIdx !== currentLesson.exercise.answer}}"> ✗</text>
          </view>
          <view wx:if="{{lessonAnswered}}" class="answer-feedback {{selectedOption === currentLesson.exercise.answer ? 'correct-fb' : 'wrong-fb'}}">
            <text>{{selectedOption === currentLesson.exercise.answer ? '🎉 回答正确！' : '💡 正确答案是：' + currentLesson.exercise.options[currentLesson.exercise.answer]}}</text>
          </view>
        </view>

        <!-- 完成按钮 -->
        <view class="complete-btn-wrap">
          <view class="complete-btn {{lessonProgress[currentLesson.id] ? 'already-done' : ''}}" bindtap="onCompleteLesson">
            <text>{{lessonProgress[currentLesson.id] ? '✅ 已完成' : '🎓 完成本课'}}</text>
          </view>
        </view>
        <view style="height: 60rpx;"></view>
      </scroll-view>
    </view>
  </view>

</view>
