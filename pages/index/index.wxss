/* pages/index/index.wxss */
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FAF0E6;
  overflow: hidden;
}

/* ── 搜索框 ── */
.search-bar {
  padding: 16rpx 24rpx 12rpx;
  background: #FFFFFF;
}

.search-inner {
  display: flex;
  align-items: center;
  background: #F5EDE3;
  border-radius: 50rpx;
  padding: 14rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #8B7265;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C1810;
  background: transparent;
}

.search-placeholder {
  color: #B09080;
  font-size: 28rpx;
}

.search-spinner {
  font-size: 22rpx;
  color: #C1440E;
  letter-spacing: 4rpx;
  padding: 0 8rpx;
}

.search-clear {
  color: #8B7265;
  font-size: 28rpx;
  padding: 0 6rpx;
}

/* 翻译结果 */
.translate-result-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: #FFF4EE;
  border-radius: 16rpx;
  border-left: 4rpx solid #C1440E;
  gap: 16rpx;
}

.translate-result-left {
  flex: 1;
}

.translate-result-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #C1440E;
  line-height: 1.4;
}

.translate-tts-btn {
  font-size: 36rpx;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(193, 68, 14, 0.08);
  flex-shrink: 0;
}

/* ── 分类筛选 ── */
.cat-scroll {
  background: #FFFFFF;
  white-space: nowrap;
  padding-bottom: 12rpx;
  flex-shrink: 0;
}

.cat-list {
  display: inline-flex;
  flex-direction: row;
  padding: 12rpx 24rpx;
  gap: 12rpx;
}

.cat-chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #8B7265;
  background: #F5EDE3;
  white-space: nowrap;
  flex-shrink: 0;
}

.cat-chip.active {
  background: #C1440E;
  color: #FFFFFF;
  font-weight: 600;
}

/* ── 词条列表 ── */
.phrase-list {
  flex: 1;
  overflow: hidden;
}

.phrase-wrapper {
  padding: 0 24rpx;
  margin-bottom: 12rpx;
}

.phrase-wrapper:first-child {
  margin-top: 16rpx;
}

/* 卡片：点击播放 */
.phrase-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 20rpx 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
  border-left: 6rpx solid transparent;
  active-opacity: 0.7;
}

.phrase-card.learned {
  border-left-color: #6B7C3B;
}

.phrase-card.faved {
  border-left-color: #F0A020;
}

.card-body {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.card-main {
  flex: 1;
}

.italian-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #C1440E;
  display: block;
  margin-bottom: 4rpx;
}

.pronunciation-text {
  font-size: 22rpx;
  color: #8B7265;
  font-style: italic;
  display: block;
  margin-bottom: 6rpx;
}

.chinese-text {
  font-size: 28rpx;
  color: #2C1810;
  display: block;
}

/* 右侧操作：收藏 + 已学 */
.card-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding-left: 20rpx;
}

.action-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.fav-off {
  color: #D0C0B0;
}

.fav-on {
  color: #F0A020;
}

  font-size: 34rpx;
  color: #D0C0B0;
}

  font-size: 34rpx;
  color: #6B7C3B;
  font-weight: 700;
}

/* Tip */
.card-tip {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #F0E0D0;
}

.tip-text {
  font-size: 22rpx;
  color: #8B7265;
  line-height: 1.5;
}

/* ── 底部统计 ── */
