/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  color: #8B7265;
}

.empty-state .emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  display: block;
}

.empty-state .text {
  font-size: 28rpx;
}
