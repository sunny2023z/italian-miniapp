<!-- pages/index/index.wxml -->
<view class="page-container">

  <!-- 智能搜索框 -->
  <view class="search-bar">
    <view class="search-inner">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索或输入任意词汇..."
        placeholder-class="search-placeholder"
        value="{{searchText}}"
        bindinput="onSearchInput"
        bindfocus="onSearchFocus"
        bindblur="onSearchBlur"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
      <view wx:if="{{translateLoading}}" class="search-spinner">···</view>
      <view wx:elif="{{searchText}}" class="search-clear" catchtap="onSearchClear">✕</view>
    </view>

    <!-- 历史搜索下拉 -->
    <view wx:if="{{showHistory && searchHistory.length > 0}}" class="history-panel">
      <view class="history-header">
        <text class="history-title">最近搜索</text>
        <view class="history-clear-btn" catchtap="onHistoryClear">清空</view>
      </view>
      <view wx:for="{{searchHistory}}" wx:key="*this" class="history-item">
        <view class="history-item-text" catchtap="onHistoryTap" data-text="{{item}}">
          <text class="history-icon">🕐</text>
          <text class="history-word">{{item}}</text>
        </view>
        <view class="history-del" catchtap="onHistoryDelete" data-text="{{item}}">✕</view>
      </view>
    </view>
  </view>

  <!-- 分类 Tag：无搜索时显示 -->
  <scroll-view wx:if="{{!searchText}}" class="cat-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
    <view class="cat-list">
      <view class="cat-chip {{selectedCat === -1 ? 'active' : ''}}" bindtap="onCatTap" data-id="-1">全部</view>
      <view
        wx:for="{{categories}}" wx:key="id"
        class="cat-chip {{selectedCat === item.id ? 'active' : ''}}"
        bindtap="onCatTap" data-id="{{item.id}}"
      >{{item.icon}} {{item.name}}</view>
    </view>
  </scroll-view>

  <!-- Phrase List -->
  <scroll-view class="phrase-list" scroll-y="true" enhanced="true" bounces="true">

    <!-- 翻译结果卡片 -->
    <view wx:if="{{translateResult}}" class="phrase-wrapper">
      <view class="phrase-card {{translateFaved ? 'faved' : ''}} translate-card" bindtap="onPlayTranslateResult">
        <view class="card-body">
          <view class="card-main">
            <text class="italian-text">{{translateItalian}}</text>
            <text class="chinese-text">{{translateChinese}}</text>
          </view>
          <view class="card-actions">
            <view class="action-icon {{translateFaved ? 'fav-on' : 'fav-off'}}" catchtap="onFavTranslate">
              {{translateFaved ? '⭐' : '☆'}}
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:for="{{filteredPhrases}}" wx:key="id" class="phrase-wrapper">
      <view class="phrase-card {{item.isFav ? 'faved' : ''}}" bindtap="onCardTap" data-id="{{item.id}}">
        <view class="card-body">
          <view class="card-main">
            <text class="italian-text">{{item.italian}}</text>
            <text class="pronunciation-text">{{item.pronunciation}}</text>
            <text class="chinese-text">{{item.chinese}}</text>
          </view>
          <view class="card-actions">
            <view class="action-icon {{item.isFav ? 'fav-on' : 'fav-off'}}" catchtap="onToggleFav" data-id="{{item.id}}">
              {{item.isFav ? '⭐' : '☆'}}
            </view>
          </view>
        </view>
        <view wx:if="{{item.tip}}" class="card-tip">
          <text class="tip-text">💡 {{item.tip}}</text>
        </view>
      </view>
    </view>

    <view style="height: 40rpx;"></view>
  </scroll-view>

</view>
